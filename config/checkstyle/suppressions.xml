<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <!-- JUnit 5 static imports are idiomatic in tests -->
    <suppress checks="AvoidStaticImport" files="[/\\]src[/\\]test[/\\]java[/\\].*"/>

    <!-- Application entry point: not a utility class in practice -->
    <suppress checks="HideUtilityClassConstructor" files="Bark\.java"/>
</suppressions>
